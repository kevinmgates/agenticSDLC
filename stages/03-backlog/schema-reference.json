{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SDLC Agent Demo — Backlog Schema Reference",
  "description": "Reference schemas for epics.json, features.json, and user-stories.json. AI-generated files must conform to these shapes.",

  "definitions": {
    "priority": {
      "type": "string",
      "enum": ["Critical", "High", "Medium", "Low"]
    },
    "epicSize": {
      "type": "string",
      "enum": ["XL", "L", "M", "S"]
    },
    "featureSize": {
      "type": "string",
      "enum": ["L", "M", "S", "XS"]
    },
    "storyPoints": {
      "type": "integer",
      "enum": [1, 2, 3, 5, 8, 13]
    },

    "epic": {
      "type": "object",
      "required": ["id", "title", "description", "business_value", "priority", "estimated_size", "linked_requirements", "tags", "acceptance_criteria"],
      "properties": {
        "id": { "type": "string", "pattern": "^EPIC-\\d{3}$" },
        "title": { "type": "string", "maxLength": 100 },
        "description": { "type": "string" },
        "business_value": { "type": "string" },
        "priority": { "$ref": "#/definitions/priority" },
        "estimated_size": { "$ref": "#/definitions/epicSize" },
        "linked_requirements": {
          "type": "array",
          "items": { "type": "string", "pattern": "^(FR|NFR|INT)-\\d{3}$" }
        },
        "tags": { "type": "array", "items": { "type": "string" } },
        "acceptance_criteria": { "type": "array", "items": { "type": "string" }, "minItems": 2 }
      }
    },

    "feature": {
      "type": "object",
      "required": ["id", "epic_id", "title", "description", "user_persona", "priority", "estimated_size", "linked_requirements", "dependencies", "acceptance_criteria", "definition_of_done"],
      "properties": {
        "id": { "type": "string", "pattern": "^FEAT-\\d{3}$" },
        "epic_id": { "type": "string", "pattern": "^EPIC-\\d{3}$" },
        "title": { "type": "string", "maxLength": 100 },
        "description": { "type": "string" },
        "user_persona": { "type": "string" },
        "priority": { "$ref": "#/definitions/priority" },
        "estimated_size": { "$ref": "#/definitions/featureSize" },
        "linked_requirements": { "type": "array", "items": { "type": "string" } },
        "dependencies": { "type": "array", "items": { "type": "string", "pattern": "^FEAT-\\d{3}$" } },
        "acceptance_criteria": { "type": "array", "items": { "type": "string" }, "minItems": 2 },
        "definition_of_done": { "type": "array", "items": { "type": "string" } }
      }
    },

    "userStory": {
      "type": "object",
      "required": ["id", "feature_id", "epic_id", "title", "user_story", "priority", "story_points", "acceptance_criteria", "tasks", "dependencies", "tags", "notes"],
      "properties": {
        "id": { "type": "string", "pattern": "^US-\\d{3}$" },
        "feature_id": { "type": "string", "pattern": "^FEAT-\\d{3}$" },
        "epic_id": { "type": "string", "pattern": "^EPIC-\\d{3}$" },
        "title": { "type": "string", "maxLength": 100 },
        "user_story": { "type": "string", "pattern": "^As a .+, I want to .+, so that .+\\.$" },
        "priority": { "$ref": "#/definitions/priority" },
        "story_points": { "$ref": "#/definitions/storyPoints" },
        "acceptance_criteria": { "type": "array", "items": { "type": "string" }, "minItems": 3 },
        "tasks": { "type": "array", "items": { "type": "string" }, "minItems": 2 },
        "dependencies": { "type": "array", "items": { "type": "string", "pattern": "^US-\\d{3}$" } },
        "tags": { "type": "array", "items": { "type": "string" } },
        "notes": { "type": "string" }
      }
    }
  },

  "files": {
    "epics.json": {
      "type": "array",
      "items": { "$ref": "#/definitions/epic" }
    },
    "features.json": {
      "type": "array",
      "items": { "$ref": "#/definitions/feature" }
    },
    "user-stories.json": {
      "type": "array",
      "items": { "$ref": "#/definitions/userStory" }
    }
  }
}
